{
  "name": "vers",
  "version": "0.1.0",
  "description": "🏷️ Opinionated version management CLI. Know where you are, bump with confidence.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vers": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "version",
    "semver",
    "bump",
    "release",
    "cli",
    "changelog"
  ],
  "author": "Vince Quarles <vince@cubicrew.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quarlwithcode/vers.git"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
